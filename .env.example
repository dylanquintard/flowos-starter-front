# Build-time variables for Vite
VITE_API_BASE_URL=http://127.0.0.1:5000/api
VITE_SITE_URL=http://127.0.0.1:8000

# Runtime variables for the Node SEO/SPA server
SEO_BACKEND_API_URL=http://127.0.0.1:5000/api
CANONICAL_SITE_URL=http://127.0.0.1:8000
SEO_CACHE_TTL_MS=300000
SEO_FETCH_TIMEOUT_MS=6000

# Optional explicit robots sitemap URL override
# SEO_ROBOTS_SITEMAP_URL=http://127.0.0.1:5000/sitemap.xml

# Usually injected by hosting platform
# PORT=10000
